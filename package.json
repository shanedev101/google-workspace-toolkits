{
  "name": "google-ws-toolkits",
  "version": "1.0.0",
  "description": "Google Workspace Toolkits - Markdown preview and privacy tools.",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc && node scripts/build.js",
    "pack": "node scripts/pack.js",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"scripts/**/*.js\" \"sidepanel.html\" \"*.json\" \"*.md\""
  },
  "keywords": [
    "chrome-extension",
    "google-workspace",
    "google-chat",
    "privacy",
    "markdown",
    "mermaid",
    "katex"
  ],
  "author": "shanedev101",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "highlight.js": "11.9.0",
    "katex": "^0.16.47",
    "markdown-it": "^14.2.0",
    "markdown-it-emoji": "3.0.0",
    "markdown-it-task-lists": "2.1.1",
    "mermaid": "^10.9.6"
  },
  "devDependencies": {
    "@types/chrome": "0.0.268",
    "@types/katex": "0.16.7",
    "@types/markdown-it": "14.1.1",
    "@types/node": "25.9.1",
    "@typescript-eslint/eslint-plugin": "7.10.0",
    "@typescript-eslint/parser": "7.10.0",
    "bestzip": "2.2.1",
    "eslint": "8.57.0",
    "eslint-config-prettier": "9.1.0",
    "prettier": "3.2.5",
    "typescript": "5.4.5",
    "vite": "^8.0.14",
    "vite-plugin-static-copy": "^4.1.0"
  }
}
